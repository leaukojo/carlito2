[gd_scene load_steps=6 format=3]

; Level template: duplicate this scene, then add
; terrain/props, drop VehicleSpawn markers, and point `info` at a LevelInfo .tres.
; It ships the pieces every level needs — env, sun, chase camera, one spawn — and
; nothing else. See src/levels/gym/gym.tscn for a fully dressed example.

[ext_resource type="Script" path="res://src/levels/base/level.gd" id="1_level"]
[ext_resource type="Script" path="res://src/vehicles/base/chase_camera.gd" id="2_cam"]
[ext_resource type="Script" path="res://src/levels/base/vehicle_spawn.gd" id="3_spawn"]

[sub_resource type="ProceduralSkyMaterial" id="SkyMat"]

[sub_resource type="Sky" id="Sky_1"]
sky_material = SubResource("SkyMat")

[sub_resource type="Environment" id="Env_1"]
background_mode = 2
sky = SubResource("Sky_1")
ambient_light_source = 3
ambient_light_energy = 0.6

[node name="Level" type="Node3D"]
script = ExtResource("1_level")

[node name="WorldEnvironment" type="WorldEnvironment" parent="."]
environment = SubResource("Env_1")

[node name="Sun" type="DirectionalLight3D" parent="."]
transform = Transform3D(0.866, 0.354, -0.354, 0, 0.707, 0.707, 0.5, -0.612, 0.612, 0, 40, 0)
shadow_enabled = true

[node name="ChaseCamera" type="Camera3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 2.5, 6)
script = ExtResource("2_cam")

[node name="Spawn" type="Marker3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.8, 0)
script = ExtResource("3_spawn")
