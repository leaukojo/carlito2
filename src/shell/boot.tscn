[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://src/shell/boot.gd" id="1_boot"]
[ext_resource type="Script" path="res://src/ui/dashboard.gd" id="2_dash"]
[ext_resource type="Script" path="res://src/ui/debug_overlay.gd" id="3_dbg"]
[ext_resource type="Script" path="res://src/ui/touch_controls.gd" id="4_touch"]

[node name="Boot" type="Node3D"]
script = ExtResource("1_boot")

[node name="UI" type="CanvasLayer" parent="."]

[node name="Label" type="Label" parent="UI"]
offset_left = 8.0
offset_top = 8.0
offset_right = 640.0
offset_bottom = 30.0
text = "carlito2 - drive: W/S, steer: A/D, handbrake: Space, horn: H, lights: L, day/night: N, camera: C, garage: G, respawn: Backspace, debug: F3, touch: F4"

[node name="Dashboard" type="Control" parent="UI"]
